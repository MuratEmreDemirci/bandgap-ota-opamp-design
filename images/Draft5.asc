SHEET 1 880 1644
TEXT -120 32 Left 2 !************************************************\n* Bandgap Reference + WS Cascode (LTspice Native)\n************************************************\n \n.param VDD=1.8\n \n* Supply\nVDD vdd 0 {VDD}\nVOUT vo 0 0\n \n************************************************\n* MOS MODELS (LTspice default - BSIM3)\n************************************************\n.model nmos NMOS (LEVEL=1 VTO=0.5 KP=200u LAMBDA=0.02)\n.model pmos PMOS (LEVEL=1 VTO=-0.5 KP=100u LAMBDA=0.02)\n \n************************************************\n* Startup / Bandgap Core\n************************************************\nMSU2 n3 n3 vdd vdd pmos W=10u L=20u\nMSU3 n3 n3 0   0   nmos W=10u L=1u\n \n************************************************\n* Bias Generators\n************************************************\nMCP vbiasp vbiasp vdd vdd pmos W=100u L=100u\nMCN vbiasn vbiasn 0   0   nmos W=100u L=100u\n \n************************************************\n* Reference Current Generator\n************************************************\nMREF nref vbiasn 0 0 nmos W=200u L=2u\nRREF nref 0 5.5k\n \n************************************************\n* Wide-Swing Cascode Current Mirror\n************************************************\n* Bottom mirror\nM1 n1 vbiasn 0 0 nmos W=50u L=2u\nM2 vo vbiasn 0 0 nmos W=50u L=2u\n \n* Cascode devices\nM3 n2 vbiasc n1 0 nmos W=50u L=2u\nM4 vo vbiasc vo 0 nmos W=50u L=2u\n \n* Cascode bias (fixed for analysis)\nVBC vbiasc 0 0.7\n \n************************************************\n* ANALYSIS\n************************************************\n* Page 1: VDD dependency\n.step param VDD 0 1.1 0.02\n \n* Page 3: VO dependency\n.dc VOUT 0 1 10m\n \n.end
