TEXT -144 24 Left 2 !************************************************\n* PAGE 1 - Bandgap Reference (PTM 180nm)\n* IREF = 10uA, VDD Dependency Analysis\n************************************************\n \n.include PTM180nm.lib\n \n.param VDD=1.8\n \n* Supply\nVDD vdd 0 {VDD}\n \n************************************************\n* Startup / Bias Core\n************************************************\nMSU2 n3 n3 vdd vdd pMOS W=10u L=20u\nMSU3 n3 n3 0   0   nMOS W=10u L=1u\n \n************************************************\n* Bias Generators\n************************************************\nMCP vbiasp vbiasp vdd vdd PMOS W=100u L=100u\nMCN vbiasn vbiasn 0   0   NMOS W=100u L=100u\n \n************************************************\n* Reference Current Branch\n************************************************\nMREF nref vbiasn 0 0 NMOS W=200u L=2u\nRREF nref 0 5.5k\n \n************************************************\n* Analysis\n************************************************\n.step param VDD 0 1.1 0.01\n \n.end
TEXT -144 1032 Left 2 ;.op
TEXT 592 24 Left 2 !************************************************\n* PAGE 3 - Bandgap + Wide-Swing Cascode Mirror\n* VO Dependency & Output Resistance\n************************************************\n \n.include PTM180nm.lib\n \n.param VDD=1.8\n \n* Supplies\nVDD vdd 0 {VDD}\nVOUT vo 0 0\n \n************************************************\n* Startup / Bandgap Core\n************************************************\nMSU2 n3 n3 vdd vdd PMOS W=10u L=20u\nMSU3 n3 n3 0   0   NMOS W=10u L=1u\n \n************************************************\n* Bias Generators\n************************************************\nMCP vbiasp vbiasp vdd vdd PMOS W=100u L=100u\nMCN vbiasn vbiasn 0   0   NMOS W=100u L=100u\n \n************************************************\n* Reference Current Generator\n************************************************\nMREF nref vbiasn 0 0 NMOS W=200u L=2u\nRREF nref 0 5.5k\n \n************************************************\n* Wide-Swing Cascode Current Mirror\n************************************************\n* Bottom mirror\nM1 n1 vbiasn 0 0 NMOS W=50u L=2u\nM2 vo vbiasn 0 0 NMOS W=50u L=2u\n \n* Cascode devices\nM3 n2 vbiasc n1 0 NMOS W=50u L=2u\nM4 vo vbiasc vo 0 NMOS W=50u L=2u\n \n************************************************\n* Bias for Cascode (simple tie for analysis)\n************************************************\n* (vbiasc is derived from vbiasn for wide-swing)\nVBC vbiasc 0 0.7\n \n************************************************\n* Analysis\n************************************************\n;.dc VOUT 0 1 1m\n \n.end
TEXT 1400 56 Left 2 !************************************************\n* Bandgap + WS Cascode (PTM180nm - FIXED)\n************************************************\n \n.include "PTM180nm.lib"\n \n.param VDD=1.8\n \nVDD vdd 0 {VDD}\nVOUT vo 0 0\n \n* Startup\nMSU2 n3 n3 vdd vdd pmos W=10u L=20u\nMSU3 n3 n3 0   0   nmos W=10u L=1u\n \n* Bias\nMCP vbiasp vbiasp vdd vdd pmos W=100u L=100u\nMCN vbiasn vbiasn 0   0   nmos W=100u L=100u\n \n* Reference branch\nMREF nref vbiasn 0 0 nmos W=200u L=2u\nRREF nref 0 5.5k\n \n* WS Cascode Mirror\nM1 n1 vbiasn 0 0 nmos W=50u L=2u\nM2 vo vbiasn 0 0 nmos W=50u L=2u\n \nM3 n2 vbiasc n1 0 nmos W=50u L=2u\nM4 vo vbiasc vo 0 nmos W=50u L=2u\n \nVBC vbiasc 0 0.7\n \n.dc VOUT 0 1 1m\n.end
