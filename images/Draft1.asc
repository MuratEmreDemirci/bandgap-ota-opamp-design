TEXT -112 24 Left 2 !***************************************\n* PTM 180nm Bandgap + WS Cascode Mirror\n***************************************\n \n.include PTM180nm.lib\n \n.param VDD=1.8\n \nVDD vdd 0 {VDD}\nVOUT vo 0 0\n \n***************************************\n* Beta-Multiplier Bias\n***************************************\nM5a vbiasp vdd vdd vdd PMOS W=100u L=2u\nM5b vbiasp vdd vdd vdd PMOS W=100u L=2u\n \n***************************************\n* Wide-Swing Cascode Mirror\n***************************************\nM1 n1 vbiasn 0 0 NMOS W=50u L=2u\nM2 vo vbiasn 0 0 NMOS W=50u L=2u\n \nM3 n2 vbiasc n1 0 NMOS W=50u L=2u\nM4 vo vbiasc vo 0 NMOS W=50u L=2u\n \n***************************************\n* Bandgap Reference Core\n***************************************\nMSU2 n3 n3 vdd vdd PMOS W=10u L=20u\nMSU3 n3 n3 0   0   NMOS W=10u L=1u\n \nMCP vbiasp vbiasp vdd vdd PMOS W=100u L=100u\nMCN vbiasn vbiasn 0   0   NMOS W=100u L=100u\n \n***************************************\n* Reference Current Branch\n***************************************\nMREF nref vbiasn 0 0 NMOS W=200u L=2u\nRREF nref 0 5.5k\n \n***************************************\n* Analysis\n***************************************\n.op\n.end
